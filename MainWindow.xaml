<Window x:Class="TourPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:views="clr-namespace:TourPlanner.Views" 
        Title="Tour Planner"
        Width="1200" 
        Height="800"
        >

    <!-- Beispiel: Button-Styles etc. (optional) -->
    <Window.Resources>
        <!-- Beispiel-Style für Buttons -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#3399CC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10 5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter 
                                HorizontalAlignment="Center" 
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Haupt-Layout: DockPanel (Menü oben, Rest unten) -->
    <DockPanel>
        <views:NavBarView DockPanel.Dock="Top"/>

        <views:TitleBarView DockPanel.Dock="Top"/>

        <!-- 3) Hauptbereich -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Linke Spalte (Tour-Liste) -->
                <ColumnDefinition Width="300"/>
                <!-- Rechte Spalte (Details) -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <!-- Oben (Tabs + Karte) -->
                <RowDefinition Height="*"/>
                <!-- Unten (Tour Logs) -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 3) ToursListView (linke Spalte) -->
            <views:ToursListView Grid.Column="0"
                                 Grid.RowSpan="2" />

            <!-- 4) TourDetailsView (rechts oben) -->
            <views:TourDetailsView Grid.Row="0" 
                                   Grid.Column="1" />

            <!-- 5) TourLogsView (rechts unten) -->
            <views:TourLogsView   Grid.Row="1"
                                  Grid.Column="1" />
        </Grid>
    </DockPanel>
</Window>

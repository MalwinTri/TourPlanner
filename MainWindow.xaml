<Window x:Class="TourPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TourPlanner.Views"
        Title="Tour Planner"
        Width="1200"
        Height="800">

    <DockPanel>
        <!-- 1) Navigation Bar -->
        <views:NavBarView DockPanel.Dock="Top" />

        <!-- 2) TitleBarView (oder SearchView o.Ä.) -->
        <views:TitleBarView DockPanel.Dock="Top" />

        <!-- 3) Hauptbereich -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Binde das DataContext des ToursListView an das MainViewModel -->
            <views:ToursListView 
                Grid.Column="0"
                Grid.RowSpan="2"
                DataContext="{Binding ToursListViewModel}" />

            <!-- Optional: TourDetailsView -->
            <views:TourDetailsView 
                Grid.Row="0"
                Grid.Column="1" 
                DataContext="{Binding SelectedTour}" />

            <!-- Optional: TourLogsView -->
            <views:TourLogsView 
                Grid.Row="1"
                Grid.Column="1"
                DataContext="{Binding SelectedTourLogs}" />
        </Grid>
    </DockPanel>
</Window>

<Window x:Class="TourPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:TourPlanner.Views"
        xmlns:viewModels="clr-namespace:TourPlanner.ViewModels"
        Background="AliceBlue"
        Title="Tour Planner"
        Width="1200" Height="800">

    <DockPanel>
        <views:NavBarView DockPanel.Dock="Top" />

        <views:TitleBarView DockPanel.Dock="Top"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <views:TourListView 
                Grid.Column="0" 
                Grid.RowSpan="2" 
                />      

            <views:TourDetailsView 
                Grid.Row="0"
                Grid.Column="1"
                />

            <views:TourLogsView 
                Grid.Row="1"
                Grid.Column="1"/>
        </Grid>
    </DockPanel>
</Window>

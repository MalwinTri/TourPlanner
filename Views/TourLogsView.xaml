<UserControl x:Class="TourPlanner.Views.TourLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border BorderBrush="#CCC" BorderThickness="1,0,0,1" Background="White" Padding="10">
        <StackPanel>
            <TextBlock Text="Tour Logs" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>

            <DataGrid ItemsSource="{Binding SelectedTourLogs}" AutoGenerateColumns="False" HeadersVisibility="Column" Height="150">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date/Time" Binding="{Binding DateTime}" />
                    <DataGridTextColumn Header="Total Time" Binding="{Binding TotalTime}" />
                    <DataGridTextColumn Header="Ranking" Binding="{Binding Ranking}" />
                    <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}" />
                    <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Border>
</UserControl>

<UserControl x:Class="TourPlanner.Views.TourLogsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >

    <Border BorderBrush="#CCC" BorderThickness="1,0,0,1" Background="White" >
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Tour Logs" FontWeight="Bold" FontSize="20" Background="#58729e"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding SelectedTourLogs}" AutoGenerateColumns="False" 
                      HeadersVisibility="Column" Height="150" 
                      ColumnHeaderHeight="40" RowHeight="30" 
                      GridLinesVisibility="None" 
                      AlternatingRowBackground="LightGray"
                      Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding DateTime}" Width="*"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding TotalTime}" Width="*"/>
                    <DataGridTextColumn Header="Distance" Binding="{Binding Ranking}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>

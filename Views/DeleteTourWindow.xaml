<Window x:Class="TourPlanner.Views.DeleteTourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete Tour" Height="200" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Are you sure you want to delete this tour?"
                       FontSize="16" FontWeight="Bold"
                       TextAlignment="Center" Margin="0,0,0,20" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Cancel" Width="100" Margin="10"
                    Command="{Binding CancelCommand}" />

                <Button Content="Delete" Width="100" Margin="10"
                    Background="Red" Foreground="White"
                    Command="{Binding DeleteCommand}" />

            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

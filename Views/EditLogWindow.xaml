<Window x:Class="TourPlanner.Views.EditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tour Log"
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Edit Tour Log"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <!-- Form Fields -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">

            <TextBlock Text="Date:" FontWeight="Bold"/>
            <DatePicker SelectedDate="{Binding DateTime, Mode=TwoWay}" Margin="0,0,0,10"/>

            <TextBlock Text="Difficulty:" FontWeight="Bold"/>
            <ComboBox SelectedItem="{Binding Difficulty, Mode=TwoWay}" Margin="0,0,0,10">
                <ComboBoxItem Content="Easy"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="Hard"/>
            </ComboBox>

            <TextBlock Text="Distance (km):" FontWeight="Bold"/>
            <TextBox Text="{Binding TotalDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Total Time (hh:mm:ss):" FontWeight="Bold"/>
            <TextBox Text="{Binding TotalTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Rating (1-5):" FontWeight="Bold"/>
            <TextBox Text="{Binding Rating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <TextBlock Text="Comment:" FontWeight="Bold"/>
            <TextBox Text="{Binding Comment, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     Height="60" AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Width="80" Margin="5" Command="{Binding SaveCommand}"/>
            <Button Content="Cancel" Width="80" Margin="5" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>

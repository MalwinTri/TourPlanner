<UserControl x:Class="TourPlanner.Views.ToursListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             MinWidth="200"
             MinHeight="400">

    <!-- Rahmen um den Inhalt -->
    <Border BorderBrush="#CCC"
            BorderThickness="1"
            Background="White"
            Padding="10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">

        <Grid>
            <!-- 3 Zeilen: 0) Titel, 1) Buttons, 2) ListBox -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Titel -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
                <RowDefinition Height="*"/>
                <!-- ListBox füllt Rest-Höhe -->
            </Grid.RowDefinitions>

            <!-- 1) Titel: jetzt linksbündig -->
            <TextBlock Grid.Row="0"
                       Text="Tours"
                       FontWeight="Bold"
                       FontSize="18"
                       Margin="10,5,0,5"
                       HorizontalAlignment="Left"
                       TextAlignment="Left"
                       Foreground="#333"/>

            <!-- 2) Buttons: jetzt linksbündig und besser verteilt -->
            <Grid Grid.Row="1" Margin="10,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Lässt Platz für zukünftige Elemente -->
                </Grid.ColumnDefinitions>

                <Button Content="+" MinWidth="30" MinHeight="30" Grid.Column="0"/>
                <Button Content="-" MinWidth="30" MinHeight="30" Grid.Column="1" Margin="5,0,0,0"/>
                <Button Content="..." MinWidth="30" MinHeight="30" Grid.Column="2" Margin="5,0,0,0"/>
            </Grid>

            <!-- 3) ListBox: füllt restliche Höhe, wird dynamisch skaliert -->
            <ListBox Grid.Row="2"
                     ItemsSource="{Binding Tours}"
                     SelectedItem="{Binding SelectedTour, Mode=TwoWay}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Stretch"
                     BorderThickness="1"
                     BorderBrush="#CCC"
                     MinHeight="150"
                     MaxHeight="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     Margin="10,10,10,0"/>
        </Grid>
    </Border>
</UserControl>

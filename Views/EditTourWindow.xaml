<Window x:Class="TourPlanner.Views.EditTourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Tour" Height="750" Width="450"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Background" Value="#58729e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#58729e"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="100"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#ccc"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Edit Tour" FontSize="24" FontWeight="Bold" Foreground="#58729e" Margin="0,0,0,20" TextAlignment="Center"/>

                <Label Content="Name"/>
                <TextBox Name="NameTextBox"/>

                <Label Content="Tour Description"/>
                <TextBox Name="DescriptionTextBox" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="200">
                        <Label Content="From"/>
                        <TextBox Name="FromTextBox"/>
                    </StackPanel>
                    <StackPanel Width="200" Margin="20,0,0,0">
                        <Label Content="To"/>
                        <TextBox Name="ToTextBox"/>
                    </StackPanel>
                </StackPanel>

                <Label Content="Transport Type"/>
                <ComboBox Name="TransportTypeComboBox">
                    <ComboBoxItem Content="Car"/>
                    <ComboBoxItem Content="Bicycle"/>
                    <ComboBoxItem Content="Walking"/>
                </ComboBox>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Width="200">
                        <Label Content="Tour Distance (km)"/>
                        <TextBox Name="DistanceTextBox"/>
                    </StackPanel>
                    <StackPanel Width="200" Margin="20,0,0,0">
                        <Label Content="Estimated Time"/>
                        <TextBox Name="EstimatedTimeTextBox"/>
                    </StackPanel>
                </StackPanel>

                <Label Content="Route Information"/>
                <TextBox Name="RouteInfoTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"/>

                <Label Content="Tour Image"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Upload Picture" Command="{Binding UploadImageCommand}" />
                    <TextBlock Name="ImageFileNameTextBlock" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <Image Name="TourImage" Height="200" Margin="0,10,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Cancel" Name="CancelButton" Background="#999" BorderBrush="#999"/>
                    <Button Content="Create" Name="SaveButton"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

<Window x:Class="TourPlanner.Views.AddLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Log" 
        Height="420" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <!-- Überschrift -->
            <RowDefinition Height="Auto" />
            <!-- Formularfelder -->
            <RowDefinition Height="*" />
            <!-- Buttons unten -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 1) Überschrift -->
        <TextBlock Text="Add Tour Log"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"
                   Grid.Row="0" />

        <!-- 2) Formularfelder -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <!-- Date/Time -->
            <TextBlock Text="Date/Time:" Margin="0,5,0,2" FontWeight="Bold"/>
            <TextBox x:Name="DateTimeTextBox" Margin="0,0,0,10" />

            <!-- Difficulty -->
            <TextBlock Text="Difficulty:" Margin="0,5,0,2" FontWeight="Bold"/>
            <ComboBox x:Name="DifficultyComboBox" Margin="0,0,0,10" SelectedIndex="0">
                <ComboBoxItem Content="Easy"/>
                <ComboBoxItem Content="Medium"/>
                <ComboBoxItem Content="Hard"/>
            </ComboBox>

            <!-- Distance -->
            <TextBlock Text="Distance (km):" Margin="0,5,0,2" FontWeight="Bold"/>
            <TextBox x:Name="DistanceTextBox" Margin="0,0,0,10" />

            <!-- Total Time -->
            <TextBlock Text="Total Time (e.g. 1h 30m):" Margin="0,5,0,2" FontWeight="Bold"/>
            <TextBox x:Name="TotalTimeTextBox" Margin="0,0,0,10" />

            <!-- Rating -->
            <TextBlock Text="Rating (1-5):" Margin="0,5,0,2" FontWeight="Bold"/>
            <TextBox x:Name="RatingTextBox" Margin="0,0,0,10" />

            <!-- Comment -->
            <TextBlock Text="Comment:" Margin="0,5,0,2" FontWeight="Bold"/>
            <TextBox x:Name="CommentTextBox" 
                     Margin="0,0,0,10" 
                     AcceptsReturn="True" 
                     Height="60"/>
        </StackPanel>

        <!-- 3) Buttons unten -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="OkButton" 
                    Content="OK" 
                    Width="80" 
                    Margin="5"
                    Click="OkButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Cancel" 
                    Width="80" 
                    Margin="5"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
